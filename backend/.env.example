# Required — get yours at https://console.groq.com
GROQ_API_KEY=

# Auth — randomly generated secret for session/ password salting
SECRET_KEY=replace_with_a_random_secret

# Optional — app works without these (mock/fallback data used)
OPENWEATHER_API_KEY=
EXCHANGE_API_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database — Supabase (replaces SQLite)
# Get these from your Supabase project: Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=your-service-role-key

# CORS — comma-separated origins allowed (default: http://localhost:3000)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
